<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{CONCEPT_TITLE}}</title>
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
mermaid.initialize({ startOnLoad: true, theme: 'neutral' });
</script>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
    line-height: 1.65;
    color: #1a1a1a;
    background: #fff;
  }
  h1 { font-size: 1.75rem; border-bottom: 3px solid #1a1a1a; padding-bottom: .5rem; margin-bottom: .3rem; }
  h2 {
    font-size: .85rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #777;
    margin-top: 2.75rem;
    margin-bottom: .6rem;
  }
  h3 { font-size: 1rem; font-weight: 700; margin: 1.25rem 0 .3rem; }
  p { margin: .7rem 0; }
  a { color: #0057b8; text-decoration: none; }
  a:hover { text-decoration: underline; }
  code {
    font-family: "JetBrains Mono", "Fira Code", "Cascadia Code", Consolas, monospace;
    font-size: .87em;
    background: #f2f2f2;
    padding: .15em .4em;
    border-radius: 4px;
  }
  pre {
    background: #f2f2f2;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
    border: 1px solid #e8e8e8;
  }
  pre code { background: none; padding: 0; font-size: .85em; }
  blockquote {
    border-left: 3px solid #d5d5d5;
    margin: 1rem 0;
    padding: .25rem 1rem;
    color: #555;
    font-style: italic;
  }
  .meta { color: #aaa; font-size: .82rem; margin-top: .2rem; }
  hr { border: none; border-top: 1px solid #ededed; margin: 2.5rem 0; }

  .mermaid { margin: 1.75rem 0; text-align: center; }

  .foundation-block { margin: 1.5rem 0; }
  .foundation-block h3 {
    font-size: .95rem;
    color: #333;
    padding-bottom: .2rem;
    border-bottom: 1px solid #ececec;
  }

  .quiz { background: #f9f9f9; border-radius: 8px; padding: 1.5rem 1.75rem; }
  .quiz details {
    margin: .85rem 0;
    border-bottom: 1px solid #ebebeb;
    padding-bottom: .85rem;
  }
  .quiz details:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
  .quiz summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    padding-left: 1.5rem;
    position: relative;
    user-select: none;
  }
  .quiz summary::-webkit-details-marker { display: none; }
  .quiz summary::before {
    content: "▶";
    position: absolute;
    left: 0;
    font-size: .7em;
    top: .3em;
    color: #aaa;
    transition: transform .15s;
  }
  details[open] > summary::before { content: "▼"; }
  .quiz .answer {
    margin-top: .65rem;
    padding: .65rem .9rem;
    background: #fff;
    border-radius: 6px;
    border: 1px solid #e4e4e4;
    font-size: .95em;
  }

  ul, ol { padding-left: 1.5rem; }
  li { margin: .35rem 0; }

  .resources ul { list-style: none; padding: 0; }
  .resources li { padding: .3rem 0; border-bottom: 1px solid #f0f0f0; }
  .resources li:last-child { border-bottom: none; }

  .footer-meta { color: #bbb; font-size: .8rem; text-align: center; margin-top: 3rem; }
</style>
</head>
<body>

<h1>{{CONCEPT_TITLE}}</h1>
<p class="meta">Session <code>{{SLUG}}</code> &nbsp;·&nbsp; {{DATE}} &nbsp;·&nbsp; <em>{{GOAL}}</em></p>


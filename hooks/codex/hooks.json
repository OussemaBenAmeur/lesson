{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/post_tool_use_codex.py",
            "timeoutSec": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/stop_codex.py",
            "timeoutSec": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/session_start_codex.py",
            "timeoutSec": 5
          }
        ]
      }
    ]
  }
}
